<script>
/* ── Clock ── */
function updateClock() {
  const now = new Date();
  document.getElementById('sys-clock').textContent = now.toLocaleTimeString('ja-JP', {hour12: false});
}
setInterval(updateClock, 1000);
updateClock();

/* ── Browser info ── */
document.getElementById('browser-lang').textContent = navigator.language || '—';
document.getElementById('session-id').textContent = 'GUEST-' + Math.random().toString(36).substring(2,10).toUpperCase();

/* ── Dropdown toggle ── */
const trigger = document.getElementById('user-menu-trigger');
const dropdown = document.getElementById('user-dropdown');

trigger.addEventListener('click', (e) => {
  e.stopPropagation();
  const open = dropdown.classList.toggle('open');
  trigger.setAttribute('aria-expanded', open);
});
document.addEventListener('click', () => {
  dropdown.classList.remove('open');
  trigger.setAttribute('aria-expanded', false);
});
dropdown.addEventListener('click', e => e.stopPropagation());

/* ── Restore session ── */
function restoreSession() {
  try {
    const raw = sessionStorage.getItem('user');
    if (raw) {
      const user = JSON.parse(raw);
      setLoggedIn(user);
    }
  } catch(e) {}
}

function setLoggedIn(user) {
  document.getElementById('user-label').textContent = user.name || user.email || 'ログイン済み';
  const iconWrap = document.getElementById('user-icon-wrap');
  if (user.picture) {
    iconWrap.innerHTML = `<img src="${user.picture}" alt="icon">`;
  }
  document.getElementById('login-section').style.display = 'none';
  document.getElementById('user-info-section').style.display = 'block';
  document.getElementById('dd-name').textContent = user.name || '—';
  document.getElementById('dd-email').textContent = user.email || '—';
  document.getElementById('logout-btn').style.display = 'block';
  document.getElementById('session-id').textContent = 'USR-' + Math.random().toString(36).substring(2,10).toUpperCase();
}

/* ── Loading sequence ── */
const loadingMessages = [
  '認証トークンを検証しています...',
  '利用者情報をデータベースと照合中...',
  'アクセス権限を確認しています...',
  'セッションを初期化しています...',
];
function showLoading(callback) {
  const overlay = document.getElementById('loading-overlay');
  const msgEl = document.getElementById('loading-msg');
  overlay.classList.add('show');
  let i = 0;
  const iv = setInterval(() => {
    i = (i + 1) % loadingMessages.length;
    msgEl.textContent = loadingMessages[i];
  }, 700);
  setTimeout(() => {
    clearInterval(iv);
    overlay.classList.remove('show');
    if (callback) callback();
  }, 3000);
}

/* ── Google Sign-In callback ── */
window.handleGoogleCredential = function(response) {
  dropdown.classList.remove('open');
  showLoading(() => {
    fetch('/api/auth/google', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ credential: response.credential }),
    })
    .then(r => r.json())
    .then(data => {
      if (data.status === 'success' && data.user) {
        sessionStorage.setItem('user', JSON.stringify(data.user));
        setLoggedIn(data.user);
        handleLoginSuccess();
      } else {
        alert('認証に失敗しました。管理者にお問い合わせください。\n（コード: AUTH_ERR_002）');
      }
    })
    .catch(() => {
      /* Demo fallback when no backend */
      const demoUser = {
        name: 'デモ利用者',
        email: 'demo@example.com',
        picture: null,
      };
      sessionStorage.setItem('user', JSON.stringify(demoUser));
      setLoggedIn(demoUser);
    });
  });
};

function handleLoginSuccess() {
  document.cookie = "login=ok; max-age=63072000; path=/; SameSite=Lax; Secure";
  location.href = '/wkt';
}

/* ── Google login button click → trigger GSI prompt ── */
/*
document.getElementById('google-login-btn').addEventListener('click', () => {
  if (window.google && window.google.accounts) {
    window.google.accounts.id.initialize({
      client_id: '699350318798-o5lftckmjckrqrb9k79p6eucvk2fkn65.apps.googleusercontent.com',
      callback: window.handleGoogleCredential,
      auto_select: false,
    });
    window.google.accounts.id.prompt((notification) => {
      if (notification.isNotDisplayed() || notification.isSkippedMoment()) {
        window.google.accounts.id.renderButton(
          document.createElement('div'),
          { theme: 'outline', size: 'large' }
        );
        alert('Googleのポップアップがブロックされました。ブラウザの設定を確認してください。');
      }
    });
  } else {
    alert('Googleログインライブラリが読み込まれていません。\nネットワーク環境を確認してください。');
  }
});
*/

document.getElementById('google-login-btn').addEventListener('click', () => {
  if (!window.google) return;

  window.google.accounts.id.initialize({
    client_id: '699350318798-o5lftckmjckrqrb9k79p6eucvk2fkn65.apps.googleusercontent.com',
    callback: window.handleGoogleCredential,
    use_fedcm_for_prompt: true
  });

  window.google.accounts.id.prompt((notification) => {
    if (notification.isNotDisplayed() || notification.isSkippedMoment()) {
      window.google.accounts.id.renderButton(
        document.getElementById('google-login-btn'),
        { theme: 'outline', size: 'large' }
      );
    }
  });
});

/* ── Logout ── */
document.getElementById('logout-btn').addEventListener('click', () => {
  sessionStorage.removeItem('user');
  location.reload();
});

/* ── Init ── */
restoreSession();
</script>

