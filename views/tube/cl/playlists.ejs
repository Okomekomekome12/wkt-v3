<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>プレイリスト</title>
  <link rel="stylesheet" href="/css/page.css">
  <script src="/js/tailwindcss.js"></script>
  <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
  <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
  <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
  <script src="/js/tube.js"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Roboto", sans-serif; background: #0f0f0f; color: #fff; overflow-x: hidden; font-size: 16px; }
    #topbar { background:#0f0f0f; border-bottom:1px solid #272727; padding:0 16px; display:flex; align-items:center; gap:10px; position:fixed; top:0; left:0; right:0; z-index:1000; height:58px; }
    .logo-wrap { display:flex; align-items:center; gap:6px; text-decoration:none; color:#fff; flex-shrink:0; }
    .logo-icon { width:30px; height:22px; background:#f00; border-radius:4px; position:relative; }
    .logo-icon::after { content:""; position:absolute; border-left:8px solid #fff; border-top:5px solid transparent; border-bottom:5px solid transparent; top:6px; left:11px; }
    .logo-text { font-size:20px; font-weight:700; letter-spacing:-0.5px; }
    .icon-btn { background:none; border:none; cursor:pointer; color:#fff; padding:8px; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .icon-btn:hover { background:#272727; }
    .search-wrap { flex:1; max-width:520px; display:flex; align-items:center; margin:0 6px; }
    #searchbox { flex:1; padding:0 16px; height:40px; border:1px solid #303030; border-right:none; border-radius:40px 0 0 40px; font-size:16px; background:#121212; color:#fff; outline:none; }
    #searchbox:focus { border-color:#1a73e8; }
    .search-submit { border:1px solid #303030; border-left:none; border-radius:0 40px 40px 0; background:#222; width:54px; height:40px; display:flex; align-items:center; justify-content:center; cursor:pointer; }
    .search-submit:hover { background:#333; }
    .search-submit svg { width:20px; height:20px; fill:#fff; }

    #sidebar {
      width: 0;
      overflow: hidden;
      background: #0f0f0f;
      border-right: 1px solid #272727;
      transition: width 0.2s ease;
      display: flex;
      flex-direction: column;
      gap: 2px;
      position: fixed;
      top: 52px;
      left: 0;
      bottom: 0;
      z-index: 50;
    }
    #sidebar.open { width: 220px; padding: 8px 0; }
    .sidebar-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 9px 20px;
      font-size: 14px;
      color: #aaa;
      cursor: pointer;
      border-radius: 8px;
      margin: 0 6px;
      white-space: nowrap;
      text-decoration: none;
    }
    .sidebar-item:hover, .sidebar-item.active { background: #272727; color: #fff; }
    .sidebar-item.active { font-weight: 600; }
    .sidebar-icon svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.8; display: block; }
    .sidebar-divider { height: 1px; background: #272727; margin: 6px 12px; flex-shrink: 0; }
    
    .page-wrap { padding-top:58px; min-height:100vh; }
    #main-content { margin-left:0; transition:margin-left 0.2s ease; max-width:900px; padding:24px 24px 60px; }

    .page-title { font-size:1.5em; font-weight:700; display:flex; align-items:center; gap:10px; margin-bottom:20px; }
    .page-title svg { width:26px; height:26px; fill:#fff; flex-shrink:0; }

    .new-pl-row { display:flex; gap:10px; margin-bottom:24px; }
    .new-pl-input { flex:1; padding:11px 16px; border-radius:12px; background:#1a1a1a; border:1px solid #2f2f2f; color:#fff; font-size:15px; outline:none; }
    .new-pl-input:focus { border-color:#1a73e8; }
    .new-pl-btn { padding:11px 20px; border-radius:12px; border:none; background:#1a73e8; color:#fff; font-size:15px; font-weight:600; cursor:pointer; white-space:nowrap; flex-shrink:0; }
    .new-pl-btn:hover { background:#1557b0; }

    #plList { display:flex; flex-direction:column; gap:10px; }

    .pl-card { background:#141414; border-radius:14px; overflow:hidden; border:1px solid #222; }

    .pl-card-header {
      display:flex; align-items:center; gap:14px;
      padding:14px 16px; cursor:pointer;
      transition:background 0.1s;
    }
    .pl-card-header:hover { background:#1a1a1a; }

    .pl-thumb-grid { flex-shrink:0; width:72px; height:72px; border-radius:8px; overflow:hidden; display:grid; grid-template-columns:1fr 1fr; grid-template-rows:1fr 1fr; gap:1px; background:#2a2a2a; }
    .pl-thumb-grid img { width:100%; height:100%; object-fit:cover; display:block; }
    .pl-thumb-grid .thumb-placeholder { width:100%; height:100%; background:#2a2a2a; }

    .pl-card-meta { flex:1; min-width:0; }
    .pl-card-name { font-size:16px; font-weight:600; margin-bottom:4px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .pl-card-count { font-size:13px; color:#aaa; }

    .pl-card-actions { display:flex; align-items:center; gap:4px; flex-shrink:0; }
    .pl-action-btn { background:none; border:none; cursor:pointer; color:#aaa; padding:7px; border-radius:50%; display:flex; align-items:center; justify-content:center; }
    .pl-action-btn:hover { background:#272727; color:#fff; }
    .pl-action-btn.danger:hover { background:#2a1515; color:#f87171; }
    .pl-action-btn svg { width:20px; height:20px; fill:currentColor; }

    .pl-chevron { transition:transform 0.2s; }
    .pl-chevron.open { transform:rotate(180deg); }

    .pl-card-body { display:none; border-top:1px solid #222; }
    .pl-card-body.open { display:block; }

    .pl-play-bar { display:flex; align-items:center; gap:10px; padding:12px 16px; border-bottom:1px solid #1f1f1f; }
    .pl-play-btn { display:flex; align-items:center; gap:8px; padding:8px 18px; border-radius:20px; border:none; background:#fff; color:#0f0f0f; font-size:14px; font-weight:700; cursor:pointer; text-decoration:none; }
    .pl-play-btn:hover { background:#ddd; }
    .pl-play-btn svg { width:16px; height:16px; fill:#0f0f0f; }
    .pl-count-label { font-size:13px; color:#aaa; }

    .pl-track-list { display:flex; flex-direction:column; }
    .pl-track-item { display:flex; align-items:center; gap:12px; padding:10px 16px; transition:background 0.1s; }
    .pl-track-item:hover { background:#1a1a1a; }
    .pl-track-item:hover .pl-track-del { opacity:1; }
    .pl-track-num { width:22px; text-align:center; font-size:13px; color:#717171; flex-shrink:0; }
    .pl-track-thumb { flex-shrink:0; width:100px; aspect-ratio:16/9; border-radius:6px; overflow:hidden; background:#1a1a1a; }
    .pl-track-thumb img { width:100%; height:100%; object-fit:cover; display:block; }
    .pl-track-info { flex:1; min-width:0; }
    .pl-track-title { font-size:14px; font-weight:500; color:#fff; text-decoration:none; display:block; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; margin-bottom:3px; }
    .pl-track-title:hover { color:#3ea6ff; }
    .pl-track-ch { font-size:13px; color:#aaa; }
    .pl-track-del { opacity:0; background:none; border:none; cursor:pointer; color:#aaa; padding:6px; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:opacity 0.15s, color 0.15s; }
    .pl-track-del:hover { color:#f87171; }
    .pl-track-del svg { width:18px; height:18px; fill:currentColor; }
    @media (hover:none) { .pl-track-del { opacity:1; } }

    .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,.75); display:flex; align-items:center; justify-content:center; z-index:3000; padding:16px; }
    .modal-card { background:#1a1a1a; border-radius:14px; padding:22px; width:100%; max-width:400px; }
    .modal-title { font-size:17px; font-weight:700; margin-bottom:14px; }
    .modal-input { width:100%; padding:11px 14px; border-radius:10px; background:#2f2f2f; border:1px solid #3f3f3f; color:#fff; font-size:15px; outline:none; margin-bottom:14px; }
    .modal-input:focus { border-color:#1a73e8; }
    .modal-btns { display:flex; gap:8px; justify-content:flex-end; }
    .modal-btn { padding:9px 20px; border-radius:10px; border:none; font-size:14px; cursor:pointer; font-weight:600; }
    .modal-btn.cancel { background:#272727; color:#aaa; }
    .modal-btn.cancel:hover { background:#3f3f3f; }
    .modal-btn.save { background:#1a73e8; color:#fff; }
    .modal-btn.save:hover { background:#1557b0; }

    .empty-state { text-align:center; padding:80px 20px; color:#555; }
    .empty-state svg { width:52px; height:52px; fill:#333; margin:0 auto 14px; display:block; }
    .empty-state p { font-size:15px; margin-bottom:6px; color:#666; }
    .empty-state small { font-size:13px; color:#444; }

    .ui-autocomplete { background:#212121 !important; border:none !important; border-radius:0 0 12px 12px !important; box-shadow:0 4px 20px rgba(0,0,0,.6) !important; z-index:10001 !important; padding:8px 0 !important; }
    .ui-menu-item-wrapper { color:#eee !important; padding:11px 18px !important; font-size:15px !important; border:none !important; }
    .ui-state-active { background:#3f3f3f !important; margin:0 !important; border:none !important; }
    .ui-helper-hidden-accessible { display:none; }

    @media (max-width:600px) {
      #main-content { padding:18px 14px 40px; }
      .pl-track-thumb { width:80px; }
    }
  </style>
</head>
<body>

<header id="topbar">
  <button class="icon-btn" onclick="toggleSidebar()">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="white"><rect x="3" y="5" width="18" height="2" rx="1"/><rect x="3" y="11" width="18" height="2" rx="1"/><rect x="3" y="17" width="18" height="2" rx="1"/></svg>
  </button>
  <a href="/wkt" class="logo-wrap">
    <div class="logo-icon"></div>
    <span class="logo-text">Tube</span>
  </a>
  <form action="/wkt/s" method="get" class="search-wrap" id="searchForm">
    <input type="text" name="q" id="searchbox" placeholder="検索" autocomplete="off">
    <button type="submit" class="search-submit">
      <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
    </button>
  </form>
</header>

  <div id="sidebar">
    <a href="/wkt" class="sidebar-item">
      <span class="sidebar-icon"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span>
      ホーム
    </a>
    <a href="/wkt/trend" class="sidebar-item">
      <span class="sidebar-icon"><svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span>
      トレンド
    </a>
    <div class="sidebar-divider"></div>
    <a href="/wkt/cl/subscriptions" class="sidebar-item">
      <span class="sidebar-icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg></span>
      登録チャンネル
    </a>
    <a href="/wkt/cl/history" class="sidebar-item">
      <span class="sidebar-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
      履歴
    </a>
    <div class="sidebar-divider"></div>
    <a href="/wkt/cl/favorites" class="sidebar-item">
      <span class="sidebar-icon"><svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg></span>
      お気に入り
    </a>
    <a href="/wkt/cl/playlists" class="sidebar-item active">
      <span class="sidebar-icon"><svg viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg></span>
      プレイリスト
    </a>
    <div class="sidebar-divider"></div>
    <a href="/wkt/settings" class="sidebar-item">
      <span class="sidebar-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14"/><path d="M4.93 4.93a10 10 0 000 14.14"/></svg></span>
      設定
    </a>
  </div>

<div class="page-wrap">
  <div id="main-content">

    <div class="page-title">
      <svg viewBox="0 0 24 24"><path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/></svg>
      プレイリスト
    </div>

    <div class="new-pl-row">
      <input type="text" id="newPlName" class="new-pl-input" placeholder="新しいプレイリスト名..." maxlength="50"
        onkeydown="if(event.key==='Enter')createPlaylist()">
      <button class="new-pl-btn" onclick="createPlaylist()">作成</button>
    </div>

    <div id="plList"></div>

  </div>
</div>

<div id="editModal" style="display:none">
  <div class="modal-overlay" onclick="if(event.target===this)closeEditModal()">
    <div class="modal-card">
      <div class="modal-title">プレイリスト名を変更</div>
      <input type="text" id="editModalInput" class="modal-input" maxlength="50"
        onkeydown="if(event.key==='Enter')saveEditModal()">
      <div class="modal-btns">
        <button class="modal-btn cancel" onclick="closeEditModal()">キャンセル</button>
        <button class="modal-btn save" onclick="saveEditModal()">保存</button>
      </div>
    </div>
  </div>
</div>

<script>
  function toggleSidebar(forceOpen = null) {
    const sb = document.getElementById('sidebar');
    const mc = document.getElementById('main-content');

    if (forceOpen === true) sb.classList.add('open');
    else if (forceOpen === false) sb.classList.remove('open');
    else sb.classList.toggle('open');

    const isOpen = sb.classList.contains('open');

    if (window.innerWidth > 1024) {
      mc.style.marginLeft = isOpen ? '240px' : '0';
    } else {
      mc.style.marginLeft = '0';
    }
    localStorage.setItem('sidebar_expanded', isOpen);
  }

  document.addEventListener('DOMContentLoaded', function() {
    const savedSidebar = localStorage.getItem('sidebar_expanded');
    const isLargeScreen = window.innerWidth > 1024;
    const isPortrait = window.innerHeight > window.innerWidth;
    if (isPortrait) {
      toggleSidebar(false);
    } else if (savedSidebar !== null) {
      toggleSidebar(savedSidebar === 'true');
    } else {
      if (isLargeScreen) {
        toggleSidebar(true);
      } else {
        toggleSidebar(false);
      }
    }
  });

  function getPlaylists() {
    try { return JSON.parse(localStorage.getItem('wkt_playlists') || '[]'); }
    catch(e) { return []; }
  }
  function savePlaylists(pls) { localStorage.setItem('wkt_playlists', JSON.stringify(pls)); }
  function genId() { return 'pl_' + Date.now() + '_' + Math.random().toString(36).slice(2,7); }

  function esc(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function createPlaylist() {
    const input = document.getElementById('newPlName');
    const name = input.value.trim();
    if (!name) { input.focus(); return; }
    const pls = getPlaylists();
    pls.unshift({ id: genId(), name, videos: [] });
    savePlaylists(pls);
    input.value = '';
    render();
  }

  function deletePlaylist(plId) {
    if (!confirm('このプレイリストを削除しますか？')) return;
    let pls = getPlaylists().filter(p => p.id !== plId);
    savePlaylists(pls);
    const el = document.getElementById('plcard_' + plId);
    if (el) {
      el.style.transition = 'opacity 0.18s, transform 0.18s';
      el.style.opacity = '0'; el.style.transform = 'translateX(10px)';
      setTimeout(() => { el.remove(); if (!document.querySelector('.pl-card')) renderEmpty(); }, 180);
    }
  }

  function deleteTrack(plId, videoId) {
    const pls = getPlaylists();
    const pl = pls.find(p => p.id === plId);
    if (!pl) return;
    pl.videos = pl.videos.filter(v => v.videoId !== videoId);
    savePlaylists(pls);
    rerenderCard(plId, true);
  }

  let _editingPlId = null;
  function openEditModal(plId) {
    _editingPlId = plId;
    const pl = getPlaylists().find(p => p.id === plId);
    if (!pl) return;
    document.getElementById('editModalInput').value = pl.name;
    document.getElementById('editModal').style.display = 'block';
    setTimeout(() => document.getElementById('editModalInput').focus(), 50);
  }
  function closeEditModal() {
    document.getElementById('editModal').style.display = 'none';
    _editingPlId = null;
  }
  function saveEditModal() {
    const name = document.getElementById('editModalInput').value.trim();
    if (!name || !_editingPlId) return;
    const pls = getPlaylists();
    const pl = pls.find(p => p.id === _editingPlId);
    if (pl) { pl.name = name; savePlaylists(pls); rerenderCard(_editingPlId, false); }
    closeEditModal();
  }

  function thumbGrid(videos) {
    const slots = [0,1,2,3].map(i => {
      const v = videos[i];
      return v
        ? `<img loading="lazy" src="/wkt/back/vi/${esc(v.videoId)}/mqdefault.jpg" alt="">`
        : `<div class="thumb-placeholder"></div>`;
    });
    return slots.join('');
  }

  function cardHtml(pl, isOpen) {
    const firstVideoId = pl.videos[0]?.videoId;
    const playUrl = firstVideoId
      ? `/wkt/watch/${esc(firstVideoId)}?playlist=${encodeURIComponent(pl.id)}`
      : '#';

    const tracksHtml = pl.videos.length
      ? pl.videos.map((v, i) => `
          <div class="pl-track-item" id="track_${esc(pl.id)}_${esc(v.videoId)}">
            <span class="pl-track-num">${i + 1}</span>
            <div class="pl-track-thumb">
              <img loading="lazy" src="/wkt/back/vi/${esc(v.videoId)}/mqdefault.jpg" alt="">
            </div>
            <div class="pl-track-info">
              <a href="/wkt/watch/${esc(v.videoId)}?playlist=${encodeURIComponent(pl.id)}"
                class="pl-track-title">${esc(v.title || '（タイトル不明）')}</a>
              <div class="pl-track-ch">${esc(v.channelName || '')}</div>
            </div>
            <button class="pl-track-del" onclick="deleteTrack('${esc(pl.id)}','${esc(v.videoId)}')" title="削除">
              <svg viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"/></svg>
            </button>
          </div>`).join('')
      : `<div style="padding:16px;color:#555;font-size:14px;text-align:center">動画がありません</div>`;

    return `
      <div class="pl-card" id="plcard_${esc(pl.id)}">
        <div class="pl-card-header" onclick="toggleCard('${esc(pl.id)}')">
          <div class="pl-thumb-grid">${thumbGrid(pl.videos)}</div>
          <div class="pl-card-meta">
            <div class="pl-card-name">${esc(pl.name)}</div>
            <div class="pl-card-count">${pl.videos.length}本の動画</div>
          </div>
          <div class="pl-card-actions" onclick="event.stopPropagation()">
            <button class="pl-action-btn" title="名前を変更" onclick="openEditModal('${esc(pl.id)}')">
              <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 000-1.41l-2.34-2.34a1 1 0 00-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
            </button>
            <button class="pl-action-btn danger" title="削除" onclick="deletePlaylist('${esc(pl.id)}')">
              <svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
            </button>
          </div>
          <svg class="pl-chevron ${isOpen ? 'open' : ''}" viewBox="0 0 24 24" width="20" height="20" fill="#aaa" style="flex-shrink:0">
            <path d="M7 10l5 5 5-5z"/>
          </svg>
        </div>
        <div class="pl-card-body ${isOpen ? 'open' : ''}">
          <div class="pl-play-bar">
            <a href="${playUrl}" class="pl-play-btn">
              <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              最初から再生
            </a>
            <span class="pl-count-label">${pl.videos.length}本</span>
          </div>
          <div class="pl-track-list">${tracksHtml}</div>
        </div>
      </div>`;
  }

  function toggleCard(plId) {
    const card = document.getElementById('plcard_' + plId);
    if (!card) return;
    const body    = card.querySelector('.pl-card-body');
    const chevron = card.querySelector('.pl-chevron');
    const isOpen  = body.classList.contains('open');
    body.classList.toggle('open', !isOpen);
    chevron.classList.toggle('open', !isOpen);
  }

  function rerenderCard(plId, keepOpen) {
    const old = document.getElementById('plcard_' + plId);
    const wasOpen = old ? old.querySelector('.pl-card-body')?.classList.contains('open') : false;
    const pls = getPlaylists();
    const pl = pls.find(p => p.id === plId);
    if (!pl || !old) return;
    const tmp = document.createElement('div');
    tmp.innerHTML = cardHtml(pl, keepOpen ? wasOpen : wasOpen);
    old.replaceWith(tmp.firstElementChild);
  }

  function renderEmpty() {
    document.getElementById('plList').innerHTML = `
      <div class="empty-state">
        <svg viewBox="0 0 24 24"><path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/></svg>
        <p>プレイリストがありません</p>
        <small>上のフォームから作成できます</small>
      </div>`;
  }

  function render() {
    const pls = getPlaylists();
    const el  = document.getElementById('plList');
    if (!pls.length) { renderEmpty(); return; }
    el.innerHTML = pls.map(pl => cardHtml(pl, false)).join('');
  }
  $(function () {
    $('#searchbox').autocomplete({
      source: function (req, cb) {
        const term = req.term.trim();
        if (term.length > 0) {
          $.ajax({ url: '/wkt/back/suggest', data: { keyword: term },
            success: function (d) {
              const h = JSON.parse(localStorage.getItem('searchHistory') || '[]');
              cb(d.length > 0 ? d : h);
            }
          });
        } else {
          cb(JSON.parse(localStorage.getItem('searchHistory') || '[]'));
        }
      },
      delay: 1, minLength: 0,
      select: function (e, ui) { $('#searchbox').val(ui.item.value); $('#searchForm').submit(); }
    });
    $('#searchbox').on('focus', function () { $(this).autocomplete('search', this.value || ''); });
  });

  render();
</script>
</body>
</html>
