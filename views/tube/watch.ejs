          <span class="sidebar-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14"/><path d="M4.93 4.93a10 10 0 000 14.14"/></svg></span>
          設定
        </a>
      </div>

<div class="page-wrap">
  <div id="page-inner">
    <div id="main-col">

      <div class="player-wrap">
        <% if (videotype === 'iframe') { %>
          <iframe src="<%= src %>" allowfullscreen allow="autoplay; encrypted-media"></iframe>
        <% } else { %>
          <div class="loading-indicator" id="loadingIndicator">
            <img src="https://cdn.glitch.global/3128bf45-3a23-4695-81ba-3aba21b8585b/IMG_1966.gif?v=1729824394361" alt="Loading">
          </div>
          <video id="video" controls preload="auto" playsinline poster="/wkt/back/vi/<%= videoId %>/maxresdefault.jpg">
            <source id="videoSrc" src="<%- src.stream_url %>" type="video/mp4">
          </video>
          <audio id="audio" style="display:none"></audio>
          <button id="erroreloadBtn" onclick="reloadVideo()">🔄 再読み込み</button>
        <% } %>
      </div>

      <div class="video-title"><%= videoInfo.title %></div>

      <div class="meta-row">
        <span class="meta-text"><%= videoInfo.viewCount %> 回視聴</span>
        <span class="meta-text">・</span>
        <span class="meta-text"><%= videoInfo.uploadDate %></span>
        <% if (videoInfo.likeCount) { %><span class="meta-text">・ <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="vertical-align: middle; margin-top: -3px;">
            <path d="M1 21h4V9H1v12zm22-11c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L14.17 1 7.59 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2z"/>
          </svg> <%= videoInfo.likeCount %></span><% } %>
        <div class="action-btns">
          <button class="action-btn" id="favBtn" onclick="toggleFav()">
            <svg viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
            お気に入り
          </button>
          <button class="action-btn" id="addToPlaylistBtn" onclick="openPlaylistModal()">
            <svg viewBox="0 0 24 24"><path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/></svg>
            プレイリスト
          </button>
        </div>
      </div>

      <div class="channel-row">
        <a href="/wkt/c/<%= videoInfo.channelId %>"><div class="ch-avatar"><% if (videoInfo.channelIcon) { %><img src="<%= videoInfo.channelIcon %>" alt=""><% } %></div></a>
        <div class="ch-info">
          <a href="/wkt/c/<%= videoInfo.channelId %>" class="ch-name"><%= videoInfo.channelName %></a>
          <% if (videoInfo.channelSubsc) { %><div class="ch-subs"><%= videoInfo.channelSubsc %></div><% } %>
        </div>
        <button class="sub-btn" id="subBtn" onclick="toggleSubscribe('<%= videoInfo.channelId %>','<%= videoInfo.channelName %>','<%= videoInfo.channelIcon %>')">登録</button>
      </div>
      <div id="playlistSection" style="display:none"></div>

        <% 
          const formatDescription = (rawText) => {
            if (!rawText) return '';
            let text = rawText;
            const ytRegex = /(?:https?:\/\/)?(?:www\.)?(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})(?:[^\s]*)/g;
            text = text.replace(ytRegex, '<a href="/wkt/watch/$1" class="wkt-link">/wkt/watch/$1</a>');
            const tagRegex = /#([^\s#!"#$%&'()*+,\-./:;<=>?@\[\\\]^`{|}~]+)/g;
            text = text.replace(tagRegex, (match, tag) => {
              return `<a href="/wkt/hashtag?q=${encodeURIComponent(tag)}" class="wkt-link">#${tag}</a>`;
            });

            return text;
          };
          const previewText = (videoInfo.description || '')
            .replace(/\n/g, ' ')
            .replace(/<br>/g, ' ');
          const fullText = formatDescription(videoInfo.description || '')
            .replace(/\n/g, '<br>');
        %>

        <% if (videoInfo.description) { %>
        <div class="desc-box" id="descBox" onclick="toggleDesc()">
          <div class="desc-preview" id="descPreview"><%- previewText %></div>
          <div class="desc-full" id="descFull"><%- fullText %></div>

          <div class="desc-toggle-row" id="descToggleRow">
            <span id="descToggleLabel">全て表示</span>
            <svg viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"/></svg>
          </div>
        </div>
        <% } %>

      <div class="comments-section">
        <div class="comments-header">
          <div class="section-title">コメント</div>
          <button class="collapse-btn" id="collapseCommentsBtn" onclick="toggleComments()">
            <svg viewBox="0 0 24 24"><path d="M7 14l5-5 5 5z"/></svg>
            閉じる
          </button>
        </div>
        <div id="commentsBody">
          <div id="commentsList"><p style="color:#aaa;font-size:15px">コメントを取得中...</p></div>
          <div id="commentError"></div>
          <button id="retryBtn" onclick="fetchComments()">再取得</button>
        </div>
      </div>
    </div>

    <div id="side-col">
      <div class="side-heading">
        <span>関連動画</span>
        <div class="view-switch" id="relatedViewSwitch" style="display:none">
          <button class="view-switch-btn active" id="vsListBtn" title="リスト" onclick="setRelatedView('list')">
            <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="2.5" rx="1"/><rect x="3" y="11" width="18" height="2.5" rx="1"/><rect x="3" y="17" width="18" height="2.5" rx="1"/></svg>
          </button>
          <button class="view-switch-btn" id="vsGridBtn" title="グリッド" onclick="setRelatedView('grid')">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" rx="1.5"/><rect x="13" y="3" width="8" height="8" rx="1.5"/><rect x="3" y="13" width="8" height="8" rx="1.5"/><rect x="13" y="13" width="8" height="8" rx="1.5"/></svg>
          </button>
        </div>
      </div>
      <div id="related-grid">
        <% const filtered = (videoInfo.relatedVideos || []).filter(v => v && v.videoId && v.title); %>
        <% filtered.forEach(v => { %>
          <a href="/wkt/watch/<%= v.videoId %>" class="related-card">
            <div class="related-thumb">
              <img loading="lazy" src="<%= v.thumbnail %>" alt="<%= v.title %>">
              <% if (v.badgeText) { %><span class="related-dur"><%= v.badgeText %></span><% } %>
            </div>
            <div class="related-info">
              <div class="related-title"><%= v.title %></div>
              <div class="related-ch"><%= v.channelName %></div>
              <div class="related-meta"><%= v.viewCountText %><% if (v.publishedText) { %> · <%= v.publishedText %><% } %></div>
            </div>
          </a>
        <% }); %>
      </div>
    </div>
  </div>
</div>

<div id="controlPanel">
  <div class="cp-header">
    <span class="cp-title">コントロール</span>
    <button class="cp-close" onclick="document.getElementById('controlPanel').classList.remove('open')">×</button>
  </div>
  <div class="cp-tabs">
    <button class="cp-tab active" onclick="switchCpTab(0)">操作</button>
    <% if (videotype === 'video') { %><button class="cp-tab" onclick="switchCpTab(1)">画質</button><% } %>
    <button class="cp-tab" onclick="switchCpTab(<%= videotype === 'video' ? 2 : 1 %>)">再生方法</button>
  </div>
  <div class="cp-slide-wrap">
    <div class="cp-slide-track" id="cpSlideTrack">

      <div class="cp-slide-page">
        <div class="cp-card">
          <div class="cp-card-title">再生</div>
          <button class="cp-btn" onclick="reloadVideo()">
            <svg viewBox="0 0 24 24"><path d="M17.65 6.35A7.958 7.958 0 0012 4C7.58 4 4 7.58 4 12s3.58 8 8 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0112 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>再読み込み
          </button>
          <% if (videotype === 'video') { %>
          <div class="cp-toggle-row">
            <span>ループ再生</span>
            <label class="toggle-switch"><input type="checkbox" id="loopToggle"><span class="slider"></span></label>
          </div>
          <% if (src.highstreamUrl) { %>
          <div class="cp-toggle-row">
            <span>高画質化</span>
            <label class="toggle-switch"><input type="checkbox" id="hdToggle"><span class="slider"></span></label>
          </div>
          <% } %>
          <% } %>
        </div>
      </div>


        <% if (videotype === 'video') { %>
          <div class="cp-slide-page">
            <% if (src.streamUrls && src.streamUrls.length > 0) { %>
              <div class="cp-card">
                <div class="cp-card-title">画質を選択</div>

                <select id="qualitySelect" class="cp-select" style="width:100%;padding:10px 12px;border-radius:10px;background:#3f3f3f;color:#fff;border:none;font-size:15px;margin-bottom:10px">
                  <% src.streamUrls.forEach(s => { %>
                    <option value="<%= s.url %>" data-resolution="<%= s.resolution %>">
                      <%= s.resolution %>
                    </option>
                  <% }); %>
                </select>

                <button class="cp-btn" id="applyQuality">
                  <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                  この画質で再生
                </button>

                <button class="cp-btn" id="resetQuality">
                  <svg viewBox="0 0 24 24"><path d="M17.65 6.35A7.958 7.958 0 0012 4C7.58 4 4 7.58 4 12s3.58 8 8 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0112 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
                  デフォルトにリセット
                </button>
              </div>
            <% } else { %>
              <p style="color:#aaa;font-size:15px;padding:8px 0">他の画質は見つかりませんでした</p>
            <% } %>
          </div>
        <% } %>

      <div class="cp-slide-page">
        <label class="cp-mode-card" id="modeNormal" onclick="selectMode('normal')">
          <input type="radio" name="playbackMode" value="normal">
          <div><div class="cp-mode-title">通常</div><div class="cp-mode-desc">ストリームURLで再生します。ほとんどの環境で動作します。</div></div>
        </label>
        <label class="cp-mode-card" id="modeEdu" onclick="selectMode('edu')">
          <input type="radio" name="playbackMode" value="edu">
          <div><div class="cp-mode-title">education</div><div class="cp-mode-desc">YouTube Educationを埋め込んで再生します。</div>
          <a href="/wkt/opu/umekomi?id=<%= videoId %>&type=edu" target="_blank" class="cp-mode-link">再生できるか確認 →</a></div>
        </label>
        <label class="cp-mode-card" id="modeNocookie" onclick="selectMode('nocookie')">
          <input type="radio" name="playbackMode" value="nocookie">
          <div><div class="cp-mode-title">nocookie</div><div class="cp-mode-desc">YouTube nocookieを埋め込んで再生します。</div>
          <a href="/wkt/opu/umekomi?id=<%= videoId %>&type=nocookie" target="_blank" class="cp-mode-link">再生できるか確認 →</a></div>
        </label>
        <button class="cp-save-btn" id="saveSettings">💾 設定を保存してリロード</button>
      </div>
    </div>
  </div>
</div>

<div id="plModal" style="display:none">
  <div class="pl-modal-overlay" onclick="if(event.target===this)closePlModal()">
    <div class="pl-modal">
      <div class="pl-modal-title">プレイリストに追加</div>
      <div class="pl-new-row">
        <input type="text" id="plNewName" class="pl-new-input" placeholder="新規プレイリスト名..." maxlength="50">
        <button class="pl-new-btn" onclick="createAndAddPlaylist()">作成して追加</button>
      </div>
      <div class="pl-list-label">プレイリスト一覧</div>
      <div class="pl-list" id="plModalList"></div>
      <button class="pl-modal-close" onclick="closePlModal()">閉じる</button>
    </div>
  </div>
</div>

<script>
  const videoId    = "<%= videoId %>";
  const channelId  = "<%= videoInfo.channelId %>";
  const channelName = "<%= videoInfo.channelName.replace(/\\/g,'\\\\').replace(/'/g,"\\'") %>";
  const channelIcon = "<%= videoInfo.channelIcon %>";
  const videoTitle  = "<%= videoInfo.title.replace(/\\/g,'\\\\').replace(/'/g,"\\'") %>";
  const durationraw  = "<%= videoInfo.duration %>";
  const duration = !durationraw.includes(":") 
  ? Math.floor(durationraw / 60) + ":" + ("0" + (durationraw % 60)).slice(-2) 
  : durationraw;
  const videoThumb  = "/wkt/back/vi/" + videoId + "/mqdefault.jpg";
  const viewCount = "<%= videoInfo.viewCount %>";
  const published = "<%= videoInfo.uploadDate %>";
  const videotype   = "<%= videotype %>";

  function toggleSidebar() {
    const sb = document.getElementById('sidebar');
    const pi = document.getElementById('page-inner');
    sb.classList.toggle('open');
    if (window.innerWidth > 1024) pi.style.marginLeft = sb.classList.contains('open') ? '240px' : '0';
  }

  function applyRelatedLayout(isBottom) {
    const pi = document.getElementById('page-inner');
    const label = document.getElementById('layoutLabel');
    const sw = document.getElementById('relatedViewSwitch');
    const currentViewMode = localStorage.getItem('relatedViewMode') || 'list';
    if (isBottom) {
      pi.classList.add('related-bottom');
      if (label) label.textContent = '関連動画を横に';
    } else {
      pi.classList.remove('related-bottom');
      if (label) label.textContent = '関連動画を下に';
    }
    if (sw) sw.style.display = 'flex';
    applyRelatedView(currentViewMode);
  }
  function toggleRelatedLayout() {
    const pi = document.getElementById('page-inner');
    const isNowBottom = !pi.classList.contains('related-bottom');
    localStorage.setItem('relatedLayout', isNowBottom ? 'bottom' : 'side');
    applyRelatedLayout(isNowBottom);
  }
  function initRelatedLayout() {
    const saved = localStorage.getItem('relatedLayout');
    const isPortrait = window.matchMedia("(max-width: 1000px)").matches || (window.innerHeight > window.innerWidth);
    if (isPortrait) {
      applyRelatedLayout(true);
    } else {
      applyRelatedLayout(saved !== null ? saved === 'bottom' : false);
    }
  }
  function applyRelatedView(mode) {
    const grid = document.getElementById('related-grid');
    const lBtn = document.getElementById('vsListBtn');
    const gBtn = document.getElementById('vsGridBtn');
    if (!grid || !lBtn || !gBtn) return;
    const isGrid = mode === 'grid';
    grid.classList.toggle('grid-view', isGrid);
    gBtn.classList.toggle('active', isGrid);
    lBtn.classList.toggle('active', !isGrid);
  }
  function setRelatedView(mode) {
    localStorage.setItem('relatedViewMode', mode);
    applyRelatedView(mode);
  }
  window.addEventListener('resize', initRelatedLayout);

  let descExpanded = false;
  function toggleDesc() {
    descExpanded = !descExpanded;
    document.getElementById('descPreview').style.display = descExpanded ? 'none' : '';
    document.getElementById('descFull').classList.toggle('show', descExpanded);
    document.getElementById('descToggleLabel').textContent = descExpanded ? '閉じる' : '全て表示';
    document.getElementById('descToggleRow').classList.toggle('open', descExpanded);
  }

  let commentsOpen = true;
  function toggleComments() {
    commentsOpen = !commentsOpen;
    const body = document.getElementById('commentsBody');
    const btn  = document.getElementById('collapseCommentsBtn');
    body.style.display = commentsOpen ? '' : 'none';
    btn.classList.toggle('collapsed', !commentsOpen);
    const path = btn.querySelector('svg path');
    path.setAttribute('d', commentsOpen ? 'M7 14l5-5 5 5z' : 'M7 10l5 5 5-5z');
    btn.lastChild.textContent = commentsOpen ? ' 閉じる' : ' 開く';
  }

  function switchCpTab(idx) {
    document.querySelectorAll('.cp-tab').forEach((t,i) => t.classList.toggle('active', i === idx));
    document.getElementById('cpSlideTrack').style.transform = 'translateX(-' + (idx * 100) + '%)';
  }

  function selectMode(mode) {
    document.querySelectorAll('.cp-mode-card').forEach(c => c.classList.remove('selected'));
    const card = document.getElementById('mode' + mode.charAt(0).toUpperCase() + mode.slice(1));
    if (card) card.classList.add('selected');
    const r = document.querySelector('input[name="playbackMode"][value="' + mode + '"]');
    if (r) r.checked = true;
  }

  async function fetchComments() {
    const list = document.getElementById('commentsList');
    const err  = document.getElementById('commentError');
    const retry = document.getElementById('retryBtn');
    list.innerHTML = '<p style="color:#aaa;font-size:15px">コメントを取得中...</p>';
    err.style.display = 'none'; retry.style.display = 'none';
    try {
      const res = await fetch('/api/yt/comment?id=' + videoId);
      if (!res.ok) throw new Error('サーバーエラー ' + res.status);
      const data = await res.json();
      if (!data.data || !data.data.length) { list.innerHTML = '<p style="color:#aaa;font-size:15px">コメントはありません</p>'; return; }
      list.innerHTML = data.data.map(c => `
        <div class="comment-item">
          <div class="comment-icon"><img loading="lazy" src="${c.authorIcon}" alt=""></div>
          <div>
            <div class="comment-author"><a href="/wkt/c/${c.authorId}">${c.authorName}</a></div>
            <div class="comment-text">${escHtml(c.text||'').replace(/\n/g,'<br>')}</div>
          </div>
        </div>`).join('');
    } catch(e) {
      list.innerHTML = ''; err.textContent = 'コメントの取得に失敗しました: ' + e.message;
      err.style.display = 'block'; retry.style.display = 'inline-block';
      showToast('コメントの取得に失敗しました', true);
    }
  }
  function escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  fetchComments();

  function getPlaylists() { return JSON.parse(localStorage.getItem('wkt_playlists') || '[]'); }
  function savePlaylists(pls) { localStorage.setItem('wkt_playlists', JSON.stringify(pls)); }
  function genPlId() { return 'pl_' + Date.now() + '_' + Math.random().toString(36).slice(2,7); }

  function openPlaylistModal() {
    renderPlModalList();
    document.getElementById('plNewName').value = '';
    document.getElementById('plModal').style.display = 'block';
  }
  function closePlModal() { document.getElementById('plModal').style.display = 'none'; }

  function renderPlModalList() {
    const container = document.getElementById('plModalList');
    if (!container) return;

    const pls = getPlaylists();
    if (pls.length === 0) {
      container.innerHTML = '<div style="text-align:center;padding:20px;color:#aaa;font-size:14px;">プレイリストがまだありません</div>';
      return;
    }

    container.innerHTML = pls.map(pl => {
      const isAdded = pl.videos && pl.videos.some(v => v.videoId === videoId);
      const hasVideos = pl.videos && pl.videos.length > 0;
      const thumbHtml = hasVideos 
        ? `<img src="${pl.videos[0].thumbnail}" loading="lazy" onerror="this.src='/wkt/back/vi/default/mqdefault.jpg'">` 
        : `<div class="pl-item-empty">EMPTY</div>`;

      return `
        <div class="pl-list-item ${isAdded ? 'added' : ''}" onclick="toggleVideoInPlaylist('${pl.id}')">
          <div class="pl-item-thumb">
            ${thumbHtml}
          </div>
          <div class="pl-item-info">
            <div class="pl-item-name">${escHtml(pl.name)}</div>
            <div class="pl-item-meta">${pl.videos.length} 本の動画</div>
          </div>
          <svg class="pl-list-item-check" viewBox="0 0 24 24" width="20" height="20">
            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" fill="#4caf50"/>
          </svg>
        </div>`;
    }).join('');
  }
  
  function createAndAddPlaylist() {
    const name = document.getElementById('plNewName').value.trim();
    if (!name) { showToast('プレイリスト名を入力してください', true); return; }
    const pls = getPlaylists();
    const newPl = { id: genPlId(), name, videos: [{ videoId, title: videoTitle, channelName, thumbnail: videoThumb }] };
    pls.unshift(newPl);
    savePlaylists(pls);
    document.getElementById('plNewName').value = '';
    renderPlModalList();
    showToast('「' + name + '」を作成して追加しました');
  }

  function toggleVideoInPlaylist(plId) {
    const pls = getPlaylists();
    const pl = pls.find(p => p.id === plId);
    if (!pl) return;
    const idx = pl.videos.findIndex(v => v.videoId === videoId);
    if (idx !== -1) {
      pl.videos.splice(idx, 1);
      showToast('「' + pl.name + '」から削除しました');
    } else {
      pl.videos.push({ videoId, title: videoTitle, channelName, thumbnail: videoThumb });
      showToast('「' + pl.name + '」に追加しました');
    }
    savePlaylists(pls);
    renderPlModalList();
  }

  function initPlaylistMode() {
    const params = new URLSearchParams(window.location.search);
    const plId = params.get('playlist');
    if (!plId) return;
    const pls = getPlaylists();
    const pl = pls.find(p => p.id === plId);
    if (!pl || !pl.videos.length) return;

    const currentIdx = pl.videos.findIndex(v => v.videoId === videoId);
    const sec = document.getElementById('playlistSection');
    sec.style.display = 'block';
            sec.innerHTML = `
              <div class="playlist-section">
                <div class="playlist-section-header">
                  <div class="playlist-section-title">プレイリスト：${escHtml(pl.name)}</div>
                  <div class="playlist-section-count">${currentIdx + 1} / ${pl.videos.length}</div>
                </div>
                <div class="playlist-track-list" id="plTrackList">
                  ${pl.videos.map((v, i) => {
                    const isCurrent = v.videoId === videoId;
                    return `<a href="/wkt/watch/${v.videoId}?playlist=${encodeURIComponent(plId)}"
                      class="playlist-track-item${isCurrent ? ' playing' : ''}"
                      id="plTrack_${i}">
                      <span class="playlist-track-num">${isCurrent ? '▶' : i + 1}</span>
                      <div class="playlist-track-thumb"><img loading="lazy" src="${v.thumbnail}" alt=""></div>
                      <div class="playlist-track-info">
                        <div class="playlist-track-title">${escHtml(v.title)}</div>
                        <div class="playlist-track-ch">${escHtml(v.channelName)}</div>
                      </div>
                    </a>`;
                  }).join('')}
                </div>
              </div>`;
  }

  function getFavs() { return JSON.parse(localStorage.getItem('wakametubefavorites') || '[]'); }
  function toggleFav() {
    let favs = getFavs();
    const btn = document.getElementById('favBtn');
    const idx = favs.findIndex(f => f.videoId === videoId);
    if (idx !== -1) { favs.splice(idx, 1); btn.classList.remove('fav-active'); showToast(videoTitle + ' のお気に入りを解除しました'); }
    else { favs.push({ videoId, channelId, channelName, videoTitle, channelIcon, duration, viewCount , published  }); btn.classList.add('fav-active'); showToast(videoTitle + ' をお気に入りに追加しました'); }
    localStorage.setItem('wakametubefavorites', JSON.stringify(favs));
  }

  function toggleSubscribe(id, name, icon) {
    const btn = document.getElementById('subBtn');
    let subs = JSON.parse(localStorage.getItem('subscriptions') || '[]');
    const idx = subs.findIndex(s => s.id === id);
    if (idx !== -1) { subs.splice(idx, 1); btn.textContent = '登録'; btn.classList.remove('subscribed'); showToast(name + ' の登録を解除しました'); }
    else { subs.push({ id, name, icon }); btn.textContent = '登録済み'; btn.classList.add('subscribed'); showToast(name + ' に登録しました'); }
    localStorage.setItem('subscriptions', JSON.stringify(subs));
  }

  function saveHistory() {
    let h = JSON.parse(localStorage.getItem('wakametubehistory') || '[]');
    h = h.filter(x => x.videoId !== videoId);
    if (h.length >= 100) h.shift();
    h.push({ videoId, channelId, channelName, videoTitle, channelIcon, duration, viewCount , published });
    localStorage.setItem('wakametubehistory', JSON.stringify(h));
  }

    function saveHashtag(description) {
        if (!description) return;

        const tagRegex = /#([^\s　!@#$%^&*()<>?.+=\[\]{}|\\/-]+)/g;
        const foundTags = [];
        let match;
        while ((match = tagRegex.exec(description)) !== null) {
            foundTags.push(match[1]);
        }

        if (foundTags.length === 0) return;

        let tagList = [];
        try {
            const saved = localStorage.getItem('wkt_tag');
            tagList = saved ? JSON.parse(saved) : [];
        } catch (e) {
            tagList = [];
        }

        foundTags.forEach(tag => {
            const existingTag = tagList.find(item => item.tag === tag);
            if (existingTag) {
                existingTag.num += 1;
            } else {
                tagList.push({ tag: tag, num: 1 });
            }
        });

        tagList.sort((a, b) => b.num - a.num);
        localStorage.setItem('wkt_tag', JSON.stringify(tagList.slice(0, 100)));
    }

    saveHashtag(<%- JSON.stringify(videoInfo.description) %>);

  document.getElementById('saveSettings').addEventListener('click', function () {
    const mode = document.querySelector('input[name="playbackMode"]:checked')?.value;
    if (!mode) return;
    document.cookie = 'playbackMode=' + mode + '; path=/; max-age=31536000';
    document.getElementById('controlPanel').classList.remove('open');
    showToast('再生方法を ' + mode + ' に変更します');
    setTimeout(() => { window.location.href = '/wkt/redirect/mode/' + videoId + '?mode=' + mode; }, 800);
  });

  $(function () {
    $('#searchbox').autocomplete({
      source: function (req, cb) {
        const term = req.term.trim();
        if (term.length > 0) { $.ajax({ url: '/wkt/back/suggest', data: { keyword: term }, success: function (d) { cb(d.length > 0 ? d : getHistory()); } }); }
        else cb(getHistory());
      },
      delay: 1, minLength: 0,
      select: function (e, ui) { $('#searchbox').val(ui.item.value); $('#searchForm').submit(); }
    });
    function getHistory() { return JSON.parse(localStorage.getItem('searchHistory') || '[]'); }
    $('#searchbox').on('focus', function () { $(this).autocomplete('search', this.value || ''); });
  });

  function showToast(text, isError) {
    const t = document.createElement('div');
    t.className = 'toast' + (isError ? ' error' : '');
    t.innerHTML = '<span>' + text + '</span><button class="toast-close" onclick="this.parentElement.remove()">×</button>';
    document.body.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateX(20px)'; setTimeout(() => t.remove(), 300); }, 3500);
  }
  function showMessage(text) { showToast(text); }
  function showerrorMessage(text) { showToast(text, true); }

  function showTutorial() {
    const ov = document.createElement('div'); ov.className = 'tut-overlay';
    ov.innerHTML = `<div class="tut-card">
      <div class="tut-title">再生方法を選択してください</div>
      <div class="tut-sub">動画が再生できる方法を選んでください。後からコントロールパネルでいつでも変更できます。埋め込みで見れるなら埋め込みで見た方が良いですよ！</div>
      <div class="tut-options">
        <div class="tut-option">
          <iframe src="https://www.youtube-nocookie.com/embed/${videoId}" allow="autoplay; encrypted-media" allowfullscreen></iframe>
          <div class="tut-option-body">
            <div class="tut-option-title">nocookie</div>
            <div class="tut-option-desc">YouTube nocookieを埋め込み再生。</div>
            <button class="tut-use-btn" onclick="setModeFromTutorial('nocookie')">これを使う</button>
          </div>
        </div>
        <div class="tut-option">
          <iframe id="tutEduFrame" allow="autoplay; encrypted-media" allowfullscreen></iframe>
          <div class="tut-option-body">
            <div class="tut-option-title">education</div>
            <div class="tut-option-desc">YouTube Educationを埋め込み再生。</div>
            <button class="tut-use-btn" onclick="setModeFromTutorial('edu')">これを使う</button>
          </div>
        </div>
        <div class="tut-option">
          <div class="tut-placeholder">
    <video controls preload="auto" playsinline 
           poster="/wkt/back/vi/${videoId}/maxresdefault.jpg"
           style="width:100%; height:100%; object-fit:contain;">
        <source id="videoSrc" src="<%- src.stream_url %>" type="video/mp4">
    </video>
</div>
          <div class="tut-option-body">
            <div class="tut-option-title">通常</div>
            <div class="tut-option-desc">ストリームURLで再生。</div>
            <button class="tut-use-btn" onclick="setModeFromTutorial('normal')">これを使う</button>
          </div>
        </div>
      </div>
      <button class="tut-skip" onclick="setModeFromTutorial('normal',true)">スキップして通常再生を使う</button>
    </div>`;
    document.body.appendChild(ov);
      fetch('/api/yt/ytedu')
      .then(r => r.json())
      .then(p => {
        const f = document.getElementById('tutEduFrame');
        if (f && p.params) {
          f.src = 'https://www.youtubeeducation.com/embed/' + videoId + p.params;
        }
      }).catch(() => {});
    window._tutOverlay = ov;
  }
  function setModeFromTutorial(mode, skip) {
    localStorage.setItem('tutorialCompleted', 'ok');
    if (window._tutOverlay) window._tutOverlay.remove();
    document.cookie = 'playbackMode=' + mode + '; path=/; max-age=31536000';
    if (mode === 'normal' || skip) showToast('再生方法を通常に設定しました');
    else window.location.href = (mode === 'nocookie' ? '/wkt/watch/' : '/wkt/watch/') + videoId + '?tu=true';
  }

  window.addEventListener('load', function () {
    initRelatedLayout();
    initPlaylistMode(); 
    if (getFavs().some(f => f.videoId === videoId)) document.getElementById('favBtn').classList.add('fav-active');
    const subs = JSON.parse(localStorage.getItem('subscriptions') || '[]');
    const subBtn = document.getElementById('subBtn');
    if (subs.some(s => s.id === channelId)) { subBtn.textContent = '登録済み'; subBtn.classList.add('subscribed'); }
    const cur = document.cookie.split('; ').find(r => r.startsWith('playbackMode='))?.split('=')[1] || 'normal';
    selectMode(cur);
    saveHistory();
    if (new URLSearchParams(window.location.search).get('tu') === 'true') showToast('再生方法を変更しました');
    const done = localStorage.getItem('tutorialCompleted');
    if (!done) showTutorial();
    else if (done === 'true') { showToast('ヒント: コントロールボタンから画質・再生方法を変更できます'); localStorage.setItem('tutorialCompleted', 'ok'); }
  });

  <% if (videotype === 'video') { %>
  const videoEl = document.getElementById('video');
  const audioEl = document.getElementById('audio');
  const videoSrcEl = document.getElementById('videoSrc');
  const loadingEl = document.getElementById('loadingIndicator');
  const errBtn = document.getElementById('erroreloadBtn');

  showToast('💡ヒント: 右上の設定から画質を変更できますよ！');

  videoEl.addEventListener('waiting', () => loadingEl.style.display = 'block');
  videoEl.addEventListener('playing', () => loadingEl.style.display = 'none');
  videoEl.addEventListener('canplay', () => { loadingEl.style.display = 'none'; errBtn.style.display = 'none'; readyZerodone = false; });
  videoEl.addEventListener('error', () => {
    showerrorMessage('動画の読み込みに失敗しました。');
    const t = videoEl.currentTime; videoEl.load();
    videoEl.addEventListener('loadedmetadata', () => { videoEl.currentTime = t; videoEl.play(); }, { once: true });
  });
  let readyZeroStart = null, readyZerodone = false;
  setInterval(() => {
    if (videoEl.readyState === 0 && !readyZerodone) {
      if (!readyZeroStart) readyZeroStart = Date.now();
      else if (Date.now() - readyZeroStart > 3000) { showerrorMessage('動画読み込みエラー。再読み込み中です...'); errBtn.style.display = 'block'; videoEl.load(); readyZerodone = true; readyZeroStart = null; }
    } else { readyZeroStart = null; }
  }, 1000);
  function reloadVideo() { errBtn.style.display = 'none'; readyZerodone = false; videoEl.load(); videoEl.play().catch(() => {}); }

  const loopToggle = document.getElementById('loopToggle');
  loopToggle.checked = localStorage.getItem('videoLoop') === 'true';
  videoEl.loop = loopToggle.checked;
  loopToggle.addEventListener('change', function () { videoEl.loop = this.checked; localStorage.setItem('videoLoop', this.checked); });

  document.getElementById('applyQuality')?.addEventListener('click', function () {
    const sel = document.getElementById('qualitySelect');
    videoSrcEl.type = 'video/webm'; videoSrcEl.src = sel.value;
    audioEl.src = '<%- src.stream_url %>';
    document.getElementById('controlPanel').classList.remove('open');
    videoEl.load(); audioEl.load();
    videoEl.addEventListener('loadedmetadata', () => videoEl.play().catch(() => {}), { once: true });
    syncAudio();
  });
  document.getElementById('resetQuality')?.addEventListener('click', function () {
    videoSrcEl.type = 'video/mp4'; videoSrcEl.src = '<%- src.stream_url %>';
    audioEl.src = ''; audioEl.pause();
    document.getElementById('controlPanel').classList.remove('open');
    videoEl.load();
  });

  <% if (src.highstreamUrl) { %>
  document.getElementById('hdToggle')?.addEventListener('change', function () {
    if (this.checked) {
      videoSrcEl.type = 'video/webm'; videoSrcEl.src = '<%- src.highstreamUrl %>';
      audioEl.src = '<%- src.stream_url %>'; videoEl.load(); audioEl.load();
      videoEl.addEventListener('loadedmetadata', () => videoEl.play().catch(() => {}), { once: true });
      syncAudio();
    } else {
      videoSrcEl.type = 'video/mp4'; videoSrcEl.src = '<%- src.stream_url %>';
      audioEl.pause(); audioEl.src = ''; videoEl.load();
    }
  });
  <% } %>

  function syncAudio() {
    videoEl.addEventListener('play', () => audioEl.play().catch(() => {}));
    videoEl.addEventListener('pause', () => { audioEl.pause(); audioEl.currentTime = videoEl.currentTime; });
    videoEl.addEventListener('ended', () => { audioEl.pause(); audioEl.currentTime = 0; });
    videoEl.addEventListener('seeked', () => { audioEl.pause(); audioEl.currentTime = videoEl.currentTime; audioEl.play().catch(() => {}); videoEl.play().catch(() => {}); });
    videoEl.addEventListener('timeupdate', () => { if (Math.abs(videoEl.currentTime - audioEl.currentTime) > 0.4) audioEl.currentTime = videoEl.currentTime + 0.1; });
  }

  let wakeLock = null;
  async function reqWakeLock() { try { if (!wakeLock) { wakeLock = await navigator.wakeLock.request('screen'); wakeLock.addEventListener('release', () => { wakeLock = null; }); } } catch(e) {} }
  videoEl.addEventListener('play', reqWakeLock);
  videoEl.addEventListener('pause', () => { if (wakeLock) wakeLock.release().then(() => { wakeLock = null; }); });
  videoEl.addEventListener('ended', () => { if (wakeLock) wakeLock.release().then(() => { wakeLock = null; }); });

  document.addEventListener('keydown', function (e) {
    if (['INPUT','TEXTAREA'].includes(document.activeElement.tagName)) return;
    if (e.code === 'Space') { e.preventDefault(); videoEl.paused ? videoEl.play() : videoEl.pause(); }
    if (e.key === 'f' || e.key === 'F') { e.preventDefault(); const fn = videoEl.requestFullscreen || videoEl.webkitRequestFullscreen; if (fn) fn.call(videoEl); }
    if (e.key === 'ArrowRight') videoEl.currentTime += 10;
    if (e.key === 'ArrowLeft')  videoEl.currentTime -= 10;
  });
  <% } else { %>
  function reloadVideo() {}
  <% } %>
</script>
</body>
</html>
