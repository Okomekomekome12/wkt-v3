<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="format-detection" content="telephone=no">
  <title><%= videoInfo.title %></title>
  <link rel="stylesheet" href="/css/page.css">
  <script src="/js/tailwindcss.js"></script>
  <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
  <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
  <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
  <script src="/js/tube.js"></script>
  <script src="/js/watch.js"></script>
  <link rel="apple-touch-icon" href="/wkt/back/vi/<%= videoId %>/maxresdefault.jpg">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Roboto", sans-serif; background: #0f0f0f; color: #fff; overflow-x: hidden; font-size: 16px; }

    #topbar { background:#0f0f0f; border-bottom:1px solid #272727; padding:0 16px; display:flex; align-items:center; gap:10px; position:fixed; top:0; left:0; right:0; z-index:1000; height:58px; }
    .logo-wrap { display:flex; align-items:center; gap:6px; text-decoration:none; color:#fff; flex-shrink:0; }
    .logo-icon { width:30px; height:22px; background:#f00; border-radius:4px; position:relative; }
    .logo-icon::after { content:""; position:absolute; border-left:8px solid #fff; border-top:5px solid transparent; border-bottom:5px solid transparent; top:6px; left:11px; }
    .logo-text { font-size:20px; font-weight:700; letter-spacing:-0.5px; }
    .icon-btn { background:none; border:none; cursor:pointer; color:#fff; padding:8px; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .icon-btn:hover { background:#272727; }
    .search-wrap { flex:1; max-width:520px; display:flex; align-items:center; margin:0 6px; }
    #searchbox { flex:1; padding:0 16px; height:40px; border:1px solid #303030; border-right:none; border-radius:40px 0 0 40px; font-size:16px; background:#121212; color:#fff; outline:none; }
    #searchbox:focus { border-color:#1a73e8; }
    .search-submit { border:1px solid #303030; border-left:none; border-radius:0 40px 40px 0; background:#222; width:54px; height:40px; display:flex; align-items:center; justify-content:center; cursor:pointer; }
    .search-submit:hover { background:#333; }
    .search-submit svg { width:20px; height:20px; fill:#fff; }
    .topbar-right { margin-left:auto; display:flex; align-items:center; gap:2px; }

    #sidebar {
      width: 0;
      overflow: hidden;
      background: #0f0f0f;
      border-right: 1px solid #272727;
      transition: width 0.2s ease;
      display: flex;
      flex-direction: column;
      gap: 2px;
      position: fixed;
      top: 52px;
      left: 0;
      bottom: 0;
      z-index: 50;
    }
    #sidebar.open { width: 220px; padding: 8px 0; }
    .sidebar-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 9px 20px;
      font-size: 14px;
      color: #aaa;
      cursor: pointer;
      border-radius: 8px;
      margin: 0 6px;
      white-space: nowrap;
      text-decoration: none;
    }
    .sidebar-item:hover, .sidebar-item.active { background: #272727; color: #fff; }
    .sidebar-item.active { font-weight: 600; }
    .sidebar-icon svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.8; display: block; }
    .sidebar-divider { height: 1px; background: #272727; margin: 6px 12px; flex-shrink: 0; }

    .page-wrap { display:flex; padding-top:58px; min-height:100vh; }
    #page-inner { display:flex; flex:1; min-width:0; }
    #main-col { flex:1; min-width:0; padding:20px 22px 40px; }

    #side-col { width:390px; min-width:390px; padding:20px 16px 40px 0; display:flex; flex-direction:column; gap:8px; }
    #page-inner.related-bottom { flex-direction:column; }
    #page-inner.related-bottom #side-col { width:100%; min-width:0; padding:0 22px 40px; }
    #page-inner.related-bottom #side-col .side-heading { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; }
    #related-grid { display:flex; flex-direction:column; gap:8px; }
    #related-grid.grid-view { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:14px; }

    .player-wrap { width:100%; aspect-ratio:16/9; background:#000; border-radius: 5px; overflow:hidden; position:relative; }
    .player-wrap iframe, .player-wrap video { position:absolute; top:0; left:0; width:100%; height:100%; border:none; }
    #erroreloadBtn { display:none; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); z-index:10; background:#1a73e8; color:#fff; border:none; border-radius:10px; padding:12px 22px; font-size:15px; cursor:pointer; }
    .loading-indicator { display:none; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); z-index:9; }
    .loading-indicator img { width:64px; height:64px; }

    .video-title { font-size:1.35em; font-weight:600; line-height:1.4; margin-top:14px; }
    .meta-row { display:flex; align-items:center; flex-wrap:wrap; gap:8px; margin-top:12px; padding-bottom:12px; border-bottom:1px solid #272727; }
    .meta-text { font-size:14px; color:#aaa; }
    .action-btns { display:flex; gap:6px; margin-left:auto; flex-wrap:wrap; }
    .action-btn { display:flex; align-items:center; gap:6px; padding:8px 16px; border-radius:20px; border:none; background:#272727; color:#fff; font-size:14px; cursor:pointer; white-space:nowrap; }
    .action-btn:hover { background:#3f3f3f; }
    .action-btn svg { width:16px; height:16px; fill:currentColor; }
    .action-btn.fav-active { color:#ff6b6b; }

    .channel-row { display:flex; align-items:center; gap:14px; padding:14px 0; border-bottom:1px solid #272727; }
    .ch-avatar { width:44px; height:44px; border-radius:50%; overflow:hidden; flex-shrink:0; background:#333; }
    .ch-avatar img { width:100%; height:100%; object-fit:cover; }
    .ch-info { flex:1; min-width:0; }
    .ch-name { font-size:15px; font-weight:600; color:#fff; text-decoration:none; display:block; }
    .ch-name:hover { color:#ddd; }
    .ch-subs { font-size:13px; color:#aaa; margin-top:2px; }
    .sub-btn { padding:9px 18px; border-radius:20px; border:none; background:#fff; color:#0f0f0f; font-size:14px; font-weight:700; cursor:pointer; flex-shrink:0; }
    .sub-btn:hover { background:#ddd; }
    .sub-btn.subscribed { background:#272727; color:#aaa; border:1px solid #3f3f3f; }

    .playlist-section {
      background: #1a1a1a;
      border: 1px solid #333;
      border-radius: 12px;
      margin: 16px 0;
      overflow: hidden;
    }

    .playlist-section-header {
      background: #282828;
      padding: 12px 16px;
      border-bottom: 1px solid #3f3f3f;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .playlist-section-title {
      font-size: 15px;
      font-weight: 700;
      color: #fff;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .playlist-section-count {
      font-size: 12px;
      color: #aaa;
      flex-shrink: 0;
    }

    .playlist-track-list {
      background: #0f0f0f;
      max-height: 360px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }

    .playlist-track-item {
      display: flex !important;
      align-items: flex-start;
      gap: 12px;
      padding: 8px 12px;
      text-decoration: none;
      color: #ccc;
      border-left: 4px solid transparent;
      transition: background 0.2s;
    }

    .playlist-track-item:hover {
      background: #1e1e1e;
    }

    .playlist-track-item.playing {
      background: #272727;
      border-left: 4px solid #3ea6ff;
      color: #3ea6ff;
    }

    .playlist-track-num {
      width: 20px;
      flex-shrink: 0;
      text-align: center;
      font-size: 13px;
      margin-top: 12px;
    }

    .playlist-track-thumb {
      width: 100px;
      aspect-ratio: 16/9;
      flex-shrink: 0;
      border-radius: 4px;
      overflow: hidden;
      background: #333;
    }

    .playlist-track-thumb img {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover;
      display: block;
    }

    .playlist-track-info {
      flex: 1;
      min-width: 0;
    }

    .playlist-track-title {
      font-size: 14px;
      font-weight: 500;
      line-height: 1.4;
      color: inherit;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-bottom: 2px;
    }

    .playlist-track-ch {
      font-size: 12px;
      color: #aaa;
    }

    .playlist-track-list::-webkit-scrollbar {
      width: 6px;
    }
    .playlist-track-list::-webkit-scrollbar-thumb {
      background: #444;
      border-radius: 3px;
    }

    .desc-box { background:#1f1f1f; border-radius:12px; padding:14px 16px; margin:14px 0; cursor:pointer; user-select:none; }
    .desc-box:hover { background:#252525; }
    .desc-preview { font-size:15px; color:#ccc; line-height:1.7; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; }
    .desc-full { display:none; font-size:15px; color:#ccc; line-height:1.7; white-space:pre-wrap; word-break:break-word; margin-top:4px; }
    .desc-full.show { display:block; }
    .desc-toggle-row { display:flex; align-items:center; gap:4px; margin-top:8px; color:#3ea6ff; font-size:14px; pointer-events:none; }
    .desc-toggle-row svg { width:16px; height:16px; fill:#3ea6ff; transition:transform 0.2s; }
    .desc-toggle-row.open svg { transform:rotate(180deg); }
    .desc-full .wkt-link {
        color: #3ea6ff;
        text-decoration: none;
    }
    .desc-full .wkt-link:hover {
        text-decoration: underline;
    }

    .pl-modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,.75); display:flex; align-items:center; justify-content:center; z-index:4000; padding:16px; }
    .pl-modal { background:#1a1a1a; border-radius:14px; padding:20px; width:100%; max-width:420px; box-shadow: 0 8px 32px rgba(0,0,0,0.5); }
    .pl-modal-title { font-size:17px; font-weight:700; margin-bottom:14px; color:#fff; }
    .pl-new-row { display:flex; gap:8px; margin-bottom:14px; }
    .pl-new-input { flex:1; padding:10px 14px; border-radius:10px; background:#2f2f2f; border:1px solid #3f3f3f; color:#fff; font-size:15px; outline:none; }
    .pl-new-input:focus { border-color:#1a73e8; }
    .pl-new-btn { padding:10px 16px; border-radius:10px; border:none; background:#1a73e8; color:#fff; font-size:14px; font-weight:600; cursor:pointer; white-space:nowrap; }

    .pl-list { display:flex; flex-direction:column; gap:8px; max-height:280px; overflow-y:auto; padding-right:4px; }
    .pl-list-item { display:flex; align-items:center; gap:12px; padding:8px; border-radius:10px; background:#272727; cursor:pointer; border:1px solid transparent; transition: background 0.2s; position: relative; }
    .pl-list-item:hover { background:#383838; }
    .pl-list-item.added { background:#1a2a1a; border-color:#2d6a2d; }

    .pl-item-thumb { width:70px; aspect-ratio:16/9; flex-shrink:0; border-radius:6px; overflow:hidden; background:#111; }
    .pl-item-thumb img { width:100%; height:100%; object-fit:cover; display:block; }
    .pl-item-empty { width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#444; font-size:10px; font-weight:bold; background:#111; }

    .pl-item-info { flex:1; min-width:0; }
    .pl-item-name { font-size:14px; font-weight:600; color:#fff; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .pl-item-meta { font-size:12px; color:#aaa; margin-top:2px; }

    .pl-list-item-check { width:20px; height:20px; fill:#4caf50; display:none; flex-shrink:0; }
    .pl-list-item.added .pl-list-item-check { display:block; }

    .pl-modal-close { width:100%; padding:10px; border-radius:10px; border:1px solid #3f3f3f; background:none; color:#aaa; font-size:15px; cursor:pointer; margin-top:14px; }
    
    .comments-section {
        margin-top: 24px;
    }

    .comments-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .section-title {
        font-size: 20px;
        font-weight: 600;
    }

    .collapse-btn {
        background: none;
        border: none;
        color: #aaa;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 16px;
        padding: 8px 14px;
        border-radius: 8px;
    }

    .collapse-btn:hover {
        background: #272727;
        color: #fff;
    }

    .collapse-btn svg {
        width: 20px;
        height: 20px;
        fill: currentColor;
        transition: transform 0.2s;
    }

    .collapse-btn.collapsed svg {
        transform: rotate(180deg);
    }

    #commentsList {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .comment-item {
        display: flex;
        gap: 16px;
    }

    .comment-icon {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        overflow: hidden;
        flex-shrink: 0;
        background: #333;
    }

    .comment-icon img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .comment-author {
        font-size: 15px;
        font-weight: 600;
        color: #fff;
        margin-bottom: 6px;
    }

    .comment-author a {
        color: #fff;
        text-decoration: none;
    }

    .comment-author a:hover {
        color: #3ea6ff;
    }

    .comment-text {
        font-size: 17px;
        color: #ccc;
        line-height: 1.6;
        word-break: break-word;
    }

    #commentError {
        color: #f87171;
        font-size: 16px;
        margin: 12px 0;
        display: none;
    }

    #retryBtn {
        display: none;
        padding: 12px 28px;
        border-radius: 24px;
        border: 1px solid #3f3f3f;
        background: none;
        color: #fff;
        font-size: 16px;
        cursor: pointer;
        margin-top: 12px;
    }

    #retryBtn:hover {
        background: #272727;
    }

    .side-heading { font-size:16px; font-weight:600; padding-bottom:8px; border-bottom:1px solid #272727; display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; }
    .related-card { display:flex; gap:10px; text-decoration:none; color:inherit; width:100%; }
    .related-card:hover .related-title { color:#3ea6ff; }
    .related-thumb { flex-shrink:0; width:160px; height:90px; border-radius:8px; overflow:hidden; background:#1a1a1a; position:relative; }
    .related-thumb img { width:100%; height:100%; object-fit:cover; display:block; }
    .related-dur { position:absolute; bottom:4px; right:4px; background:rgba(0,0,0,.85); color:#fff; font-size:12px; font-weight:700; padding:2px 5px; border-radius:3px; }
    .related-info { flex:1; min-width:0; }
    .related-title { font-size:14px; font-weight:500; line-height:1.4; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; margin-bottom:4px; }
    .related-ch, .related-meta { font-size:12px; color:#aaa; }
    #related-grid { display:flex; flex-direction:column; gap:12px; }
    @media (max-width: 1000px) {
      .related-card { gap:16px; margin-bottom:4px; }
      .related-thumb { width:360px; height:202px; border-radius:12px; }
      .related-title { font-size:18px; }
      #related-grid { gap:20px; }
      #related-grid.grid-view { grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:32px 16px; }
    }
    .related-bottom #related-grid { gap:20px; padding:16px 0; }
    .related-bottom .related-card { gap:16px; }
    .related-bottom .related-thumb { width:360px; height:202px; border-radius:12px; }
    .related-bottom .related-title { font-size:18px; }
    #related-grid.grid-view { display:grid; grid-template-columns:repeat(auto-fill, minmax(160px, 1fr)); gap:16px 10px; }
    #related-grid.grid-view .related-card { flex-direction:column; }
    #related-grid.grid-view .related-thumb { width:100%; height:auto; aspect-ratio:16/9; }
    .related-bottom #related-grid.grid-view { grid-template-columns:repeat(auto-fill, minmax(300px, 1fr)); gap:32px 16px; }
    .related-bottom #related-grid.grid-view .related-thumb { width:100%; height:auto; }
    .view-switch { display:flex; background:#272727; border-radius:16px; padding:2px; gap:1px; }
    .view-switch-btn { background:none; border:none; width:32px; height:28px; border-radius:14px; cursor:pointer; color:#aaa; display:flex; align-items:center; justify-content:center; padding:0; }
    .view-switch-btn.active { background:#555; color:#fff; }
    .view-switch-btn svg { width:16px; height:16px; fill:currentColor; pointer-events:none; }

    #controlPanel { display:none; position:fixed; bottom:20px; right:20px; width:440px; height:500px; background:#181818; border:1px solid #3f3f3f; border-radius:16px; z-index:2000; box-shadow:0 12px 40px rgba(0,0,0,.7); overflow:hidden; flex-direction:column; }
    #controlPanel.open { display:flex; }
    .cp-header { display:flex; align-items:center; padding:14px 16px 0; gap:8px; flex-shrink:0; }
    .cp-title { font-size:16px; font-weight:600; flex:1; }
    .cp-close { background:none; border:none; color:#aaa; font-size:24px; cursor:pointer; line-height:1; }
    .cp-tabs { display:flex; gap:4px; padding:10px 16px 0; flex-shrink:0; }
    .cp-tab { padding:8px 16px; border-radius:20px; border:none; background:#272727; color:#aaa; font-size:14px; cursor:pointer; transition:background 0.15s; }
    .cp-tab.active { background:#fff; color:#0f0f0f; font-weight:600; }
    .cp-slide-wrap { flex:1; overflow:hidden; position:relative; }
    .cp-slide-track { display:flex; height:100%; transition:transform 0.25s cubic-bezier(0.4,0,0.2,1); }
    .cp-slide-page { min-width:100%; height:100%; overflow-y:auto; padding:14px 16px 18px; }
    .cp-card { background:#272727; border-radius:12px; padding:14px; margin-bottom:10px; }
    .cp-card-title { font-size:12px; color:#aaa; margin-bottom:10px; text-transform:uppercase; letter-spacing:.6px; font-weight:600; }
    .cp-btn { display:flex; align-items:center; gap:8px; width:100%; padding:11px 14px; border-radius:10px; border:none; background:#3f3f3f; color:#fff; font-size:15px; cursor:pointer; margin-bottom:8px; text-align:left; }
    .cp-btn:hover { background:#555; }
    .cp-btn svg { width:17px; height:17px; fill:currentColor; flex-shrink:0; }
    .cp-btn:last-child { margin-bottom:0; }
    .cp-toggle-row { display:flex; align-items:center; justify-content:space-between; padding:10px 0; font-size:15px; }
    .cp-toggle-row + .cp-toggle-row { border-top:1px solid #3a3a3a; }
    .toggle-switch { position:relative; width:46px; height:26px; flex-shrink:0; }
    .toggle-switch input { opacity:0; width:0; height:0; }
    .toggle-switch .slider { position:absolute; inset:0; background:#555; border-radius:26px; cursor:pointer; transition:background 0.2s; }
    .toggle-switch .slider:before { content:""; position:absolute; width:20px; height:20px; left:3px; top:3px; background:#fff; border-radius:50%; transition:transform 0.2s; }
    .toggle-switch input:checked + .slider { background:#1a73e8; }
    .toggle-switch input:checked + .slider:before { transform:translateX(20px); }
    .cp-mode-card { display:flex; align-items:flex-start; gap:12px; background:#272727; border-radius:12px; padding:14px; margin-bottom:8px; cursor:pointer; border:2px solid transparent; transition:border-color 0.15s; }
    .cp-mode-card:hover { background:#303030; }
    .cp-mode-card.selected { border-color:#1a73e8; }
    .cp-mode-card input[type=radio] { margin-top:2px; flex-shrink:0; accent-color:#1a73e8; width:16px; height:16px; }
    .cp-mode-title { font-size:15px; font-weight:600; margin-bottom:4px; }
    .cp-mode-desc { font-size:13px; color:#aaa; line-height:1.5; }
    .cp-mode-link { color:#3ea6ff; font-size:13px; text-decoration:none; }
    .cp-save-btn { width:100%; padding:12px; border-radius:10px; border:none; background:#1a73e8; color:#fff; font-size:15px; font-weight:600; cursor:pointer; margin-top:4px; }
    .cp-save-btn:hover { background:#1557b0; }

    .layout-toggle-btn { display:flex; align-items:center; gap:5px; padding:7px 13px; border-radius:20px; border:none; background:#272727; color:#fff; font-size:14px; cursor:pointer; white-space:nowrap; }
    .layout-toggle-btn:hover { background:#3f3f3f; }
    .layout-toggle-btn svg { width:15px; height:15px; fill:currentColor; }

    .toast { position:fixed; top:70px; right:16px; background:#212121; border:1px solid #3f3f3f; border-radius:10px; padding:14px 18px; font-size:15px; color:#fff; z-index:9999; display:flex; align-items:center; gap:12px; box-shadow:0 4px 20px rgba(0,0,0,.5); max-width:360px; transition:opacity .3s,transform .3s; }
    .toast.error { border-color:#f87171; background:#2a1515; }
    .toast-close { background:none; border:none; color:#aaa; cursor:pointer; font-size:20px; flex-shrink:0; }

    .tut-overlay { position:fixed; inset:0; background:rgba(0,0,0,.85); display:flex; align-items:center; justify-content:center; z-index:3000; padding:16px; overflow-y:auto; }
    .tut-card { background:#1a1a1a; border-radius:16px; padding:24px; width:100%; max-width:900px; }
    .tut-title { font-size:20px; font-weight:700; margin-bottom:6px; text-align:center; }
    .tut-sub { font-size:15px; color:#aaa; text-align:center; margin-bottom:20px; }
    .tut-options { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; }
    .tut-option { background:#272727; border-radius:12px; overflow:hidden; }
    .tut-option iframe, .tut-placeholder, .tut-placeholder video { width:100%; aspect-ratio:16/9; border:none; background:#111; display:flex; align-items:center; justify-content:center; color:#666; font-size:14px; }
    .tut-option-body { padding:14px; }
    .tut-option-title { font-size:15px; font-weight:700; margin-bottom:4px; }
    .tut-option-desc { font-size:13px; color:#aaa; margin-bottom:12px; line-height:1.4; }
    .tut-use-btn { width:100%; padding:10px; border-radius:8px; border:none; background:#1a73e8; color:#fff; font-size:14px; font-weight:600; cursor:pointer; }
    .tut-use-btn:hover { background:#1557b0; }
    .tut-skip { display:block; text-align:center; margin-top:16px; color:#aaa; font-size:14px; cursor:pointer; background:none; border:none; width:100%; }
    .tut-skip:hover { color:#fff; }
    @media (max-width:600px) { .tut-options { grid-template-columns:1fr; } .tut-card { padding:16px; } }
    @media (min-width:601px) and (max-width:860px) { .tut-options { grid-template-columns:repeat(2,1fr); } }

    .ui-autocomplete { background:#212121 !important; border:none !important; border-radius:0 0 12px 12px !important; box-shadow:0 4px 20px rgba(0,0,0,.6) !important; z-index:10001 !important; padding:8px 0 !important; }
    .ui-menu-item-wrapper { color:#eee !important; padding:11px 18px !important; font-size:15px !important; border:none !important; }
    .ui-state-active { background:#3f3f3f !important; margin:0 !important; border:none !important; }
    .ui-helper-hidden-accessible { display:none; }

    @media (max-width:1100px) { #side-col { width:340px; min-width:340px; } }
    @media (max-width:900px) {
      #page-inner { flex-direction:column; }
      #side-col { width:100%; min-width:0; padding:0 22px 40px; }
      .layout-toggle-btn { display:none; }
      #controlPanel { width:calc(100vw - 32px); right:16px; bottom:16px; height:460px; }
    }
  </style>
</head>
<body>

